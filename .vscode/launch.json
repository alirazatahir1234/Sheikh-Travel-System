{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch SheikhTravelSystem.API (.NET)",
      "type": "dotnet",
      "request": "launch",
      "projectPath": "${workspaceFolder}/Backend/SheikhTravelSystem.API/SheikhTravelSystem.API.csproj",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development"
      }
    },
    {
      "name": "Launch SheikhTravelSystem.API (CoreCLR)",
      "type": "coreclr",
      "request": "launch",
      "preLaunchTask": "build-api",
      "program": "${workspaceFolder}/Backend/SheikhTravelSystem.API/bin/Debug/net10.0/SheikhTravelSystem.API.dll",
      "args": [],
      "cwd": "${workspaceFolder}/Backend/SheikhTravelSystem.API",
      "stopAtEntry": false,
      "console": "integratedTerminal",
      "env": {
        "ASPNETCORE_ENVIRONMENT": "Development",
        "ASPNETCORE_URLS": "http://localhost:5082"
      },
      "serverReadyAction": {
        "action": "openExternally",
        "pattern": "\\bNow listening on:\\s+(https?://\\S+)"
      }
    }
  ]
}
